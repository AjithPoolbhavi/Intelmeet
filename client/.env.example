# Client Environment Variables
# Copy this file to .env and fill in your actual values

# === API Configuration ===
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000

# === Production URLs ===
VITE_API_URL_PROD=https://api.yourdomain.com/api
VITE_SOCKET_URL_PROD=https://yourdomain.com

# === Feature Flags ===
VITE_ENABLE_DEMO_MODE=false
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_AI_FEATURES=true

# === App Configuration ===
VITE_APP_NAME=IntellMeet Premium
VITE_APP_VERSION=1.0.0

# === OpenAI Configuration (if using client-side) ===
VITE_OPENAI_API_KEY=sk-your_key_here

# === Authentication ===
VITE_JWT_STORAGE_KEY=intellmeet_token
VITE_REFRESH_TOKEN_KEY=intellmeet_refresh_token

# === Development ===
VITE_DEBUG=false
VITE_LOG_LEVEL=info

# === Performance ===
VITE_ENABLE_SOURCE_MAPS=true

# === WebRTC ===
VITE_ICE_SERVERS=stun:stun.l.google.com:19302

# === Testing ===
VITE_TEST_USER_EMAIL=test@example.com
VITE_TEST_USER_PASSWORD=testpassword123
